<div class="manage-page">
  <nav class="manage-nav">
    <%= link_to "← フィード管理", feeds_path %>
  </nav>

  <h1>フィードを編集</h1>

  <% if @feed.errors.any? || @subscription.errors.any? %>
    <div class="form-errors">
      <ul>
        <% @feed.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
        <% @subscription.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with url: feed_path(@feed), method: :patch, class: "manage-form" do |form| %>
    <div class="manage-form-field">
      <label>フィードURL</label>
      <p class="manage-table-url"><%= @feed.url %></p>
    </div>

    <div class="manage-form-field">
      <%= form.label :title, "タイトル" %>
      <%= form.text_field :title, value: @subscription.title, name: "subscription[title]", class: "manage-input", autofocus: true %>
    </div>

    <div class="manage-form-field">
      <%= form.label :fetch_interval_minutes, "巡回間隔" %>
      <%= form.select :fetch_interval_minutes,
          Feed::FETCH_INTERVAL_OPTIONS.map { |k, v| [v, k] },
          { selected: @feed.fetch_interval_minutes },
          name: "feed[fetch_interval_minutes]", class: "manage-select" %>
    </div>

    <div class="manage-form-field">
      <%= form.label :rate, "レート" %>
      <%= form.select :rate,
          [[  "未設定", 0 ],
           [  "★",     1 ],
           [  "★★",   2 ],
           [  "★★★",  3 ],
           [ "★★★★",  4 ],
           ["★★★★★",  5 ]],
          { selected: @subscription.rate },
          name: "subscription[rate]", class: "manage-select" %>
    </div>

    <div class="manage-form-field">
      <%= form.label :folder_id, "フォルダ" %>
      <%= form.select :folder_id,
          @folders.map { |f| [f.name, f.id] },
          { include_blank: "（未分類）", selected: @subscription.folder_id },
          name: "subscription[folder_id]", class: "manage-select" %>
    </div>

    <div>
      <%= form.submit "保存", class: "manage-submit" %>
    </div>
  <% end %>
</div>
