<%= turbo_frame_tag "entry_list", refresh: :morph do %>
  <button class="mobile-back-button" data-action="click->mobile-pane#showFeeds">&larr; フィード</button>
  <div class="pane-header">
    <h2>ピン一覧</h2>
  </div>

  <div class="entry-list">
    <% if @entries.any? %>
      <% @entries.each do |entry| %>
        <%= render "entries/entry", entry: entry, pinned: true, feed_name: true %>
      <% end %>
    <% else %>
      <p class="empty-message">ピン留めされたエントリはありません</p>
    <% end %>
  </div>
<% end %>
