<%= turbo_frame_tag "entry_list", data: { controller: "hatena-bookmark", feed_id: @feed.id } do %>
  <button class="mobile-back-button" data-action="click->mobile-pane#showFeeds">&larr; フィード</button>
  <div class="pane-header">
    <h2><%= @feed.title || @feed.url %></h2>
  </div>

  <div class="entry-list">
    <% if @entries.any? %>
      <% @entries.each do |entry| %>
        <%= link_to entry_path(entry), data: { turbo_frame: "entry_detail", entry_url: entry.safe_url_for_link }, class: "entry-item #{'entry-unread' unless @entry_states.dig(entry.id, :read)}", id: "entry_#{entry.id}", tabindex: "-1" do %>
          <div class="entry-title-row">
            <% if @entry_states.dig(entry.id, :pinned) %>
              <span class="pin-icon">📌</span>
            <% end %>
            <span class="entry-title"><%= entry.title || "（タイトルなし）" %></span>
          </div>
          <div class="entry-meta">
            <% if entry.published_at %>
              <time datetime="<%= entry.published_at.iso8601 %>">
                <%= entry.published_at.strftime("%Y-%m-%d %H:%M") %>
              </time>
            <% end %>
            <% if entry.author.present? %>
              <span class="entry-author"><%= entry.author %></span>
            <% end %>
            <span class="hatena-count"></span>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="empty-message">エントリがありません</p>
    <% end %>
  </div>
<% end %>
