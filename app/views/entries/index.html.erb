<%= turbo_frame_tag "entry_list", refresh: :morph, data: { controller: "hatena-bookmark", feed_id: @feed.id } do %>
  <button class="mobile-back-button" data-action="click->mobile-pane#showFeeds">&larr; フィード</button>
  <div class="pane-header">
    <h2><%= @feed.title || @feed.url %></h2>
  </div>

  <div class="entry-list">
    <% if @entries.any? %>
      <% @entries.each do |entry| %>
        <%= render "entries/entry", entry: entry,
              unread: !@entry_states.dig(entry.id, :read),
              pinned: @entry_states.dig(entry.id, :pinned),
              author: true, hatena: true, entry_url: entry.safe_url_for_link %>
      <% end %>
    <% else %>
      <p class="empty-message">エントリがありません</p>
    <% end %>
  </div>
<% end %>
