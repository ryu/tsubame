<%# locals: (entry:, unread: false, pinned: false, feed_name: false, author: false, hatena: false, entry_url: nil) %>
<%= link_to entry_path(entry), data: { turbo_frame: "entry_detail", entry_url: entry_url }.compact, class: "entry-item #{'entry-unread' if unread}", id: "entry_#{entry.id}", tabindex: "-1" do %>
  <div class="entry-title-row">
    <% if pinned %>
      <span class="pin-icon">📌</span>
    <% end %>
    <span class="entry-title"><%= entry.title || "（タイトルなし）" %></span>
  </div>
  <div class="entry-meta">
    <% if feed_name %>
      <span class="entry-feed-name"><%= entry.feed.title %></span>
    <% end %>
    <% if entry.published_at %>
      <time datetime="<%= entry.published_at.iso8601 %>">
        <%= entry.published_at.strftime("%Y-%m-%d %H:%M") %>
      </time>
    <% end %>
    <% if author && entry.author.present? %>
      <span class="entry-author"><%= entry.author %></span>
    <% end %>
    <% if hatena %>
      <span class="hatena-count"></span>
    <% end %>
  </div>
<% end %>
