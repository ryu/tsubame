<turbo-frame id="entry_detail">
  <button class="mobile-back-button" data-action="click->mobile-pane#showEntries">&larr; エントリ</button>
  <article class="entry-detail">
    <header class="entry-header">
      <h2><%= entry.title || "（タイトルなし）" %></h2>
      <div class="entry-meta">
        <% if entry.published_at %>
          <time datetime="<%= entry.published_at.iso8601 %>">
            <%= entry.published_at.strftime("%Y年%m月%d日 %H:%M") %>
          </time>
        <% end %>
        <% if entry.author.present? %>
          <span class="entry-author">by <%= entry.author %></span>
        <% end %>
      </div>
      <div class="entry-actions">
        <%= button_to entry_pin_path(entry), class: "pin-button" do %>
          <%= pinned ? "📌 ピン解除" : "📌 ピン留め" %>
        <% end %>
        <% if entry.safe_url_for_link.present? %>
          <%= link_to "元記事を開く", entry.safe_url_for_link, target: "_blank", rel: "noopener noreferrer", class: "external-link" %>
          <%= link_to "はてブに追加", "https://b.hatena.ne.jp/entry/panel/?url=#{ERB::Util.url_encode(entry.safe_url_for_link)}", target: "_blank", rel: "noopener noreferrer", class: "external-link hatena-add-link" %>
        <% end %>
      </div>
    </header>

    <div class="entry-body">
      <%= sanitize entry.body, tags: %w[p br div span strong em b i a ul ol li blockquote pre code h1 h2 h3 h4 h5 h6 img hr table thead tbody tr td th dl dt dd figure figcaption sup sub del ins small], attributes: %w[href src alt title width height colspan rowspan] %>
    </div>
  </article>

  <nav class="mobile-entry-nav">
    <button class="mobile-entry-nav-button" data-action="click->selection#previousEntry" data-selection-target="prevButton" aria-label="前のエントリに移動">&#8249; 前のエントリ</button>
    <button class="mobile-entry-nav-button" data-action="click->selection#nextEntry" data-selection-target="nextButton" aria-label="次のエントリに移動">次のエントリ &#8250;</button>
  </nav>
</turbo-frame>
